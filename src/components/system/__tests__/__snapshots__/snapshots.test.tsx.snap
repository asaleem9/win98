exports[`BSOD snapshots > custom error message 1`] = `
<div>
  <div
    class="fixed inset-0 z-[99999] bg-[#0000AA] flex items-center justify-center p-8 cursor-default"
  >
    <div
      class="max-w-[600px] text-white font-[family-name:var(--win98-font-fixedsys)] text-[14px] leading-relaxed"
    >
      <div
        class="text-center mb-4"
      >
        <span
          class="bg-[#A8A8A8] text-[#0000AA] px-2"
        >
           Windows 
        </span>
      </div>
      <p
        class="mb-4"
      >
        A problem has been detected and Windows has been shut down
         in VxD VMCPD(01) + 00010E36. The current application will be terminated.
      </p>
      <p
        class="mb-4"
      >
        * Press any key to terminate the current application.
        <br />
        * Press CTRL+ALT+DEL to restart your computer. You will
        <br />
          lose any unsaved information in all applications.
      </p>
      <p
        class="text-center mt-8"
      >
        Press any key to continue 
        <span
          class="animate-pulse"
        >
          _
        </span>
      </p>
    </div>
  </div>
</div>
`;

